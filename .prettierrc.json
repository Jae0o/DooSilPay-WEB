{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "endOfLine": "lf",

  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^@(app|pages|widgets|features|entities|shared)(/.*)?$",
    "^\\.\\./",
    "^\\./"
  ],

  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
